GROQ_API_KEY=your_groq_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
LLM_PROVIDER=groq
SUPABASE_URL=your_supabase_url_here
# Must be the service_role key, not anon — backend enforces authorization itself.
SUPABASE_KEY=your_supabase_service_role_key_here
# Direct Postgres connection string, for Alembic migrations only (NOT used by
# the app's normal request path). From Supabase: Project Settings -> Database
# -> Connection string -> "Session pooler" mode.
DATABASE_URL=postgresql://postgres.xxxxx:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres
FRONTEND_URL=https://careerdnaai.vercel.app
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=your_random_jwt_secret_here
